    {
      "parameters": {
        "jsCode": "// Extract subscriber info from checkout.session.completed\nconst session = $input.first().json.eventData?.object || {};\n\n// Telegram chat_id should be passed as metadata or client_reference_id\nconst chatId = session.metadata?.telegram_chat_id || session.client_reference_id || '';\nconst username = session.metadata?.telegram_username || '';\nconst stripeCustomerId = session.customer || '';\nconst priceId = session.metadata?.price_id || '';\nconst category = session.metadata?.category || 'all';\n\n// Use the documented Framed+ price ID from _Framed-Project.md.\nconst FRAMED_PLUS_PRICE_ID = 'price_1T93Nw3JAJzIMzIJZXm9IiBA';\nconst tier = priceId === FRAMED_PLUS_PRICE_ID ? 'framed+' : 'framed';\n\nconst today = new Date().toISOString().split('T')[0];\n\nif (!chatId) {\n  throw new Error('No telegram_chat_id in session metadata or client_reference_id');\n}\n\nreturn [{\n  json: {\n    chat_id: chatId,\n    username,\n    tier,\n    active: true,\n    category,\n    subscription_state: 'active',\n    stripe_customer_id: stripeCustomerId,\n    subscribed_date: today\n  }\n}];"
      },
