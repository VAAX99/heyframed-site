      "parameters": {
        "jsCode": "// Parse the Stripe event type from the raw body\nconst body = $input.first().json.body || $input.first().json;\nconst eventType = body.type || '';\nconst eventData = body.data || {};\n\nreturn [{\n  json: {\n    eventType,\n    eventData,\n    rawBody: body\n  }\n}];"
      },
      "id": "node-parse-event",
